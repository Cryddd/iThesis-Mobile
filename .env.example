# ---------------------------------------------------------------------------
# iThesis Mobile — environment configuration
# Copy this file to `.env` and set the value for your setup.
#
# The mobile app ONLY talks to the Django REST API. The Django backend keeps
# using the existing LOCAL PostgreSQL database (no migration, no Supabase as the
# primary DB). To reach the local backend from a phone over the internet, expose
# Django with a static public IP or a tunnel (Ngrok / Cloudflare Tunnel) and put
# that URL here (must end with /api/v1, no trailing slash).
# ---------------------------------------------------------------------------

# Local Android emulator reaching the host machine's Django:
# EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:8000/api/v1

# Local iOS simulator:
# EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:8000/api/v1

# Real device on the same Wi-Fi (use your machine's LAN IP):
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.20:8000/api/v1

# Ngrok tunnel (off-campus testing):
# EXPO_PUBLIC_API_BASE_URL=https://your-subdomain.ngrok-free.app/api/v1

# Cloudflare Tunnel:
# EXPO_PUBLIC_API_BASE_URL=https://ithesis.yourdomain.com/api/v1

# Production (library server with a static public IP / domain):
EXPO_PUBLIC_API_BASE_URL=https://ithesis.batstate-u.edu.ph/api/v1
